{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:webview:allow-set-webview-zoom",
    "opener:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "binaries/backend", "sidecar": true, "args": true }
      ]
    }
  ]
}
